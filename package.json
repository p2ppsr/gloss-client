{
  "name": "gloss-client",
  "version": "0.4.12",
  "description": "Global developer logging SDK backed by per-controller daily BSV spend chains",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "keywords": [
    "bsv",
    "blockchain",
    "logging",
    "developer-tools",
    "kvstore",
    "global",
    "discoverable"
  ],
  "author": "P2PPSR",
  "license": "Open BSV License",
  "repository": {
    "type": "git",
    "url": "https://github.com/p2ppsr/gloss-client.git"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@bsv/sdk": "^2.1.7"
  }
}
